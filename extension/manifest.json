{
  "manifest_version": 3,
  "name": "aichatctl bridge",
  "version": "0.1.0",
  "description": "Deterministic automation bridge for Claude.ai and ChatGPT projects (drives your real, logged-in session).",
  "permissions": ["scripting", "tabs", "debugger", "alarms", "storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "ws://127.0.0.1/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}

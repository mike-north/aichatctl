{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": false,
    "types": ["node", "jest"]
  }
}

{
  "name": "aichatctl-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "license": "MIT",
  "description": "Drive Claude.ai, ChatGPT, Gemini, and NotebookLM web UIs from agents: sync project files, seed chat sessions, and create podcasts.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean && rimraf packages/*/dist packages/*/temp",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "api": "pnpm --filter @aichatctl/sdk run api",
    "plugin:build": "aipm build",
    "plugin:validate": "aipm validate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@ai-plugin-marketplace/cli": "^0.2.0",
    "@ai-plugin-marketplace/core": "^0.3.0",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsd": "^0.31.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}

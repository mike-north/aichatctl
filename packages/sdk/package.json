{
  "name": "@aichatctl/sdk",
  "version": "0.1.0",
  "description": "Core engine for driving the Claude.ai, ChatGPT, Gemini, and NotebookLM web UIs: platform drivers, transports, and the file-sync engine.",
  "license": "MIT",
  "author": "Mike North <michael.l.north@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike-north/aichatctl.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/mike-north/aichatctl#readme",
  "bugs": "https://github.com/mike-north/aichatctl/issues",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/sdk.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "api": "api-extractor run --local && api-documenter markdown -i temp -o docs",
    "api:check": "api-extractor run"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "^7.26.0",
    "@microsoft/api-extractor": "^7.58.0",
    "@types/js-yaml": "^4.0.9"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1"
  }
}
